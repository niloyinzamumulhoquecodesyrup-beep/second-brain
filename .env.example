# Copy this file to .env.local and fill in real values. Never commit .env.local.

# Postgres connection string (Supabase pooler works well here)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@aws-1-ap-south-1.pooler.supabase.com:6543/postgres

# Random secret used to sign session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace_with_a_long_random_string

# Only needed when running `npm run seed:user` to create/update the single account.
SEED_EMAIL=you@example.com
SEED_PASSWORD=choose_a_strong_password

# Supabase project URL + anon key, used client-side (browser bundle) so the "Other
# Brains" tab can subscribe to Realtime updates directly against Supabase. Safe to
# expose: every table it can reach has RLS locked down to deny-all except explicit
# public-read policies on other_brains_messages/suggestions/books (see
# migrations/020_rls_lockdown.sql and 021_other_brains.sql). Find these under
# Project Settings > API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_with_your_anon_key
