# Environment variables (do NOT commit your real password or DATABASE_URL)
# Copy this file to .env.local and replace the value with your actual connection string.
# Example (do NOT commit .env.local into git):
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@aws-1-ap-south-1.pooler.supabase.com:6543/postgres

DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@aws-1-ap-south-1.pooler.supabase.com:6543/postgres
